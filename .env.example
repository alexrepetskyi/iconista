# --- Databases (external, connection strings) ---
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/iconista
REDIS_URL=redis://default:pass@host:6379

# --- Site ---
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Auth (npx auth secret) ---
AUTH_SECRET=change-me
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# 'mock' = local dev without Stripe: the purchase completes through the same
# fulfillment code, no payment form. NEVER set 'mock' in production.
PAYMENT_MODE=stripe

# --- Content ---
# Default hero video when no drop has one yet
HERO_VIDEO_FALLBACK_URL=https://g-essestore.com/cdn/shop/videos/c/vp/0e645a4ccaab4bfa8ca26c25b4409735/0e645a4ccaab4bfa8ca26c25b4409735.HD-1080p-7.2Mbps-78053183.mp4

# --- Emails ---
RESEND_API_KEY=re_...
EMAIL_FROM="ICONISTA <hello@iconista.example>"

# --- LLM translations ---
ANTHROPIC_API_KEY=sk-ant-...

# --- S3 (product photos & files) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
AWS_BUCKET_NAME=iconista-uploads
